# syntax=docker/dockerfile:1.4

ARG BASE_IMAGE_TAG=v2-latest-dev
FROM 1525745393/build-mdcx-base:$BASE_IMAGE_TAG AS builder

LABEL maintainer="1525745393"
LABEL description="base on 1525745393/mdcx-build-base:$BASE_IMAGE_TAG"

ARG APP_VERSION
ARG TARGETPLATFORM
ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
ARG BUILDPLATFORM
ARG BUILDOS
ARG BUILDARCH
ARG BUILDVARIANT

# 输出构建信息
RUN echo "-----Image platform details:" && \
  echo "Target: $TARGETPLATFORM ($TARGETOS/$TARGETARCH/$TARGETVARIANT)" && \
  echo "Build: $BUILDPLATFORM ($BUILDOS/$BUILDARCH/$BUILDVARIANT)"

COPY build-mdcx/.mdcx_src /tmp/mdcx
WORKDIR /tmp/mdcx

# 设置PyPI镜像
ARG PYPI_MIRROR
# ARG DEFAULT_MIRROR="https://pypi.doubanio.com/simple"
# ARG DEFAULT_MIRROR=""
ENV PYPI_MIRROR=${PYPI_MIRROR:-${DEFAULT_MIRROR}}

# 移除上游 pyproject.toml 中的 required-environments 限制
# 上游仅声明了 x86_64 等平台，ARM64 构建时 uv sync 会拒绝安装
# 实际依赖在 ARM64 下均可正常工作，此处仅解除环境检查
RUN python3.13 -c "import re;c=open('pyproject.toml','r').read();open('pyproject.toml','w').write(re.sub(r'required-environments\s*=\s*\[[\s\S]*?\]','# required-environments removed for multi-arch build',c))"

# 安装依赖（uv sync 会根据 pyproject.toml 安装项目依赖和 dev 依赖）
# 注意：不使用 uv pip install -e . 因为上游项目 flat-layout 会导致 setuptools 报错
RUN uv sync --all-extras --dev

# 保存版本信息
RUN mkdir -p ./dist && echo $APP_VERSION > ./dist/app-version

# 安装依赖并构建
RUN echo "PYPI_MIRROR: $PYPI_MIRROR" && \
  uv run pyinstaller -n MDCx \
  -F -w main.py \
  --add-data "resources:resources" \
  --add-data "libs:." \
  --hidden-import socks \
  --hidden-import urllib3 \
  --hidden-import _cffi_backend \
  --hidden-import PIL \
  --hidden-import PIL.Image \
  --hidden-import PIL.ImageFile \
  --hidden-import PIL.ImageFilter \
  --hidden-import PIL._imaging \
  --hidden-import PyQt6 \
  --hidden-import httpx \
  --hidden-import h11 \
  --hidden-import h2 \
  --hidden-import hyperframe \
  --hidden-import parsel \
  --hidden-import pydantic_settings \
  --hidden-import openai \
  --hidden-import openai.types.chat \
  --hidden-import cv2 \
  --hidden-import lxml \
  --hidden-import lxml.etree \
  --hidden-import jinja2 \
  --hidden-import jinja2.sandbox \
  --hidden-import aiofiles \
  --hidden-import aiolimiter \
  --hidden-import av \
  --hidden-import bs4 \
  --hidden-import oshash \
  --hidden-import ping3 \
  --hidden-import pydantic \
  --hidden-import zhconv \
  --hidden-import numpy \
  --collect-all PyQt6 \
  --collect-all curl_cffi && \
  # 保存版本信息
  echo $APP_VERSION > /tmp/mdcx/dist/app-version && \
  # 清理构建缓存
  rm -rf /tmp/mdcx/build /tmp/mdcx/__pycache__ /root/.cache/pip

# 最终镜像仅用于存储和分发二进制文件
FROM alpine:latest

COPY --from=builder --chmod=+x /tmp/mdcx/dist/MDCx /MDCx
COPY --from=builder /tmp/mdcx/dist/app-version /app-version

CMD [ "echo", "This image just contains MDCx bin." ]
